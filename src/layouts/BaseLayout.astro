---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  pageId?: string;
}

const { title = "Cedar Connor — Creative Technologist", description = "Real-time graphics, generative AI, projection, VR, and interactive installations.", pageId } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#050505" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='%23050505'/%3E%3Ctext x='50' y='62' font-family='serif' font-size='52' fill='%23e58e26' text-anchor='middle'%3EC%3C/text%3E%3C/svg%3E" />
  </head>
  <body data-page-id={pageId}>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script is:inline>
      // Best-effort: ask the YouTube player for the highest quality. YouTube
      // adapts to player size + bandwidth and treats this as a hint, so it's
      // not guaranteed — but it nudges embeds away from defaulting low.
      (function () {
        var frames = document.querySelectorAll("iframe[data-yt-hq]");
        if (!frames.length) return;
        function forceHigh(player) {
          try { player.setPlaybackQualityRange("hd1080", "highres"); } catch (e) {}
          try { player.setPlaybackQuality("hd1080"); } catch (e) {}
        }
        function upgrade() {
          frames.forEach(function (f) {
            try {
              new YT.Player(f, {
                events: {
                  onReady: function (e) { forceHigh(e.target); },
                  onStateChange: function (e) { if (e.data === 1) forceHigh(e.target); },
                },
              });
            } catch (e) {}
          });
        }
        if (window.YT && window.YT.Player) { upgrade(); return; }
        var prev = window.onYouTubeIframeAPIReady;
        window.onYouTubeIframeAPIReady = function () { if (typeof prev === "function") prev(); upgrade(); };
        if (!document.getElementById("yt-iframe-api")) {
          var s = document.createElement("script");
          s.id = "yt-iframe-api";
          s.src = "https://www.youtube.com/iframe_api";
          document.head.appendChild(s);
        }
      })();

      (function () {
        if (window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        var tiles = document.querySelectorAll(".tile, .repo-card, .model-card");
        if (!("IntersectionObserver" in window) || !tiles.length) return;
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) { e.target.classList.add("in"); io.unobserve(e.target); }
          });
        }, { rootMargin: "0px 0px -8% 0px" });
        tiles.forEach(function (t, i) {
          t.classList.add("reveal");
          t.style.transitionDelay = Math.min(i % 8, 6) * 40 + "ms";
          io.observe(t);
        });
      })();
    </script>
  </body>
</html>
