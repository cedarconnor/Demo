---
import type { Project } from "../lib/projects";
import { categories } from "../lib/projects";
import { url } from "../lib/url";
import thumbIds from "../data/thumbs.json";

interface Props {
  project: Project;
}
const { project } = Astro.props;
const yt = project.youtubeId || "";
const hasYouTube = yt.length > 0;
// Self-hosted thumbnail (downloaded by scripts/fetch-thumbs.mjs). Videos without
// a usable thumbnail aren't in the manifest and render a clean branded card.
const hasThumb = hasYouTube && (thumbIds as string[]).includes(yt);
const thumbUrl = hasThumb ? url("/thumbs/" + yt + ".jpg") : "";
// Belt-and-suspenders: if the local file ever 404s, fall back to YouTube live.
const liveFallback = hasYouTube ? "https://i.ytimg.com/vi/" + yt + "/hqdefault.jpg" : "";
const onerror = hasThumb ? "this.onerror=null;this.src='" + liveFallback + "'" : "";
const cat = categories[project.category] || project.category;
const tileClass = hasThumb ? "tile" : "tile placeholder";
const href = url("/work/" + project.slug);
const durSuffix = project.duration ? " · " + project.duration : "";
---
<a class={tileClass} href={href} aria-label={project.title}>
  {hasThumb && <img class="thumb" src={thumbUrl} alt={project.title} loading="lazy" onerror={onerror} />}
  {!hasThumb && <div class="thumb"></div>}
  {hasYouTube && (
    <span class="play" aria-hidden="true">
      <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
    </span>
  )}
  <div class="meta">
    <div>
      <div class="t">{project.title}</div>
      <div class="c">{cat}{durSuffix}</div>
    </div>
  </div>
</a>
