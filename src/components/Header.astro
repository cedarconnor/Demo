---
import { url, BASE } from "../lib/url";
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const stripped = BASE && path.startsWith(BASE) ? (path.slice(BASE.length) || "/") : path;
function isActive(p) {
  if (stripped === p) return true;
  if (p !== "/" && stripped.startsWith(p)) return true;
  return false;
}
---
<header class="site-header">
  <div class="wrap">
    <a href={url("/")} class="brand">Cedar&nbsp;Connor</a>
    <nav class="nav" aria-label="Primary">
      <a href={url("/")} aria-current={isActive("/") ? "page" : undefined}>Index</a>
      <a href={url("/work")} aria-current={isActive("/work") ? "page" : undefined}>Work</a>
      <a href={url("/code")} aria-current={isActive("/code") ? "page" : undefined}>Code</a>
      <a href={url("/about")} aria-current={isActive("/about") ? "page" : undefined}>About</a>
      <a href={url("/contact")} aria-current={isActive("/contact") ? "page" : undefined}>Contact</a>
    </nav>
  </div>
</header>
