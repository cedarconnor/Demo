---
import BaseLayout from "../layouts/BaseLayout.astro";
import { email } from "../lib/projects";
---
<BaseLayout pageId="about" title="About — Cedar Connor" description="Generative Effects Supervisor at Sphere Studios — generative-AI VFX for the largest screens ever built.">
  <section class="wrap" style="padding-top: clamp(4rem, 10vh, 8rem); padding-bottom: 4rem;">
    <div class="eyebrow">About</div>
    <h1 style="margin-top: 1rem;">Cedar&nbsp;Connor.</h1>
    <p class="lead" style="margin-top: 1.75rem;">
      I'm a director and technologist with over a decade leading VFX and creative-technology
      teams. Today I'm Generative Effects Supervisor at Sphere Studios, directing generative-AI
      VFX for the Las Vegas Sphere — the largest LED screens ever built.
    </p>
    <p class="lead" style="margin-top: 1rem;">
      My work lives between generative AI and traditional VFX: building ComfyUI and diffusion
      pipelines, training custom models for 360°/spherical formats, and figuring out the unknowns by
      <em style="color: var(--accent); font-style: italic;">building the thing.</em>
    </p>
    <p style="margin-top: 2.5rem;">
      <a
        href={`mailto:${email}`}
        style="color: var(--accent); border-bottom: 1px solid currentColor; font-family: var(--type-display); font-size: clamp(1.2rem, 2.5vw, 1.8rem);"
      >{email}</a>
    </p>
  </section>
</BaseLayout>
