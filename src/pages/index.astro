---
import BaseLayout from "../layouts/BaseLayout.astro";
import { url } from "../lib/url";
import featured from "../data/featured.json";

// Tools of choice — grouped, current as of the Sphere Studios role.
const tools = [
  {
    group: "Generative AI",
    items: "ComfyUI · Flux · Wan · Qwen · Hunyuan · Stable Diffusion · LoRA training · ControlNets",
  },
  {
    group: "VFX & 3D",
    items: "Nuke · Maya · Houdini · Cinema 4D · Gaussian Splats · Adobe Creative Cloud",
  },
  {
    group: "Real-time & finishing",
    items: "Unreal · Notch · TouchDesigner · DaVinci Resolve",
  },
];
---
<BaseLayout pageId="home">
  <section class="wrap" style="padding-top: clamp(3rem, 8vh, 6rem); padding-bottom: 2rem;">
    <div class="eyebrow">Generative Effects Supervisor · Sphere Studios</div>
    <h1 style="margin-top: 1.25rem;">
      I direct generative VFX<br />
      for the <em style="font-style: italic; color: var(--accent);">largest screens ever built.</em>
    </h1>
  </section>

  <!-- Tools of choice -->
  <section class="wrap" style="margin-top: 3.5rem;">
    <div class="eyebrow">Tools of choice</div>
    <div class="tools">
      {tools.map((t) => (
        <div class="tool-row">
          <div class="tool-group">{t.group}</div>
          <div class="tool-items">{t.items}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Highlighted work — self-hosted thumbnail cards -->
  <section class="wrap" style="margin-top: 4.5rem; margin-bottom: 2rem;">
    <div class="eyebrow">Selected work</div>
    {featured.groups.map((group) => (
      <>
        <h2 style="margin-top: 0.85rem; margin-bottom: 1.5rem;">{group.heading}</h2>
        <div class="grid-cinema" style="margin-bottom: 3rem;">
          {group.items.map((item) => (
            <a
              class="tile"
              href={`https://www.youtube.com/watch?v=${item.youtubeId}`}
              target="_blank"
              rel="noopener"
              aria-label={item.title}
            >
              <img
                class="thumb"
                src={url("/thumbs/" + item.youtubeId + ".jpg")}
                alt={item.title}
                loading="lazy"
                onerror={`this.onerror=null;this.src='https://i.ytimg.com/vi/${item.youtubeId}/hqdefault.jpg'`}
              />
              <span class="play" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
              </span>
              <div class="meta">
                <div>
                  <div class="t">{item.title}</div>
                  <div class="c">{group.note}</div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </>
    ))}
  </section>
</BaseLayout>

<style>
  /* Tools of choice — editorial rows */
  .tools {
    margin-top: 1.25rem;
    max-width: 70rem;
  }
  .tool-row {
    display: grid;
    grid-template-columns: minmax(140px, 15rem) 1fr;
    gap: 1.5rem;
    padding: 1.1rem 0;
    border-top: 1px solid var(--line);
  }
  .tool-row:last-child {
    border-bottom: 1px solid var(--line);
  }
  .tool-group {
    font-family: var(--type-mono);
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent-soft);
  }
  .tool-items {
    color: var(--fg);
    line-height: 1.6;
  }
  @media (max-width: 640px) {
    .tool-row {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
  }
</style>
