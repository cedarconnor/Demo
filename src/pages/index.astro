---
import BaseLayout from "../layouts/BaseLayout.astro";
import VideoEmbed from "../components/VideoEmbed.astro";

// Tools of choice — grouped, current as of the Sphere Studios role.
const tools = [
  {
    group: "Generative AI",
    items: "ComfyUI · Flux · Wan · Qwen · Hunyuan · Stable Diffusion · LoRA training · ControlNets · image-to-video",
  },
  {
    group: "VFX & 3D",
    items: "Nuke · Maya · Houdini · Cinema 4D · Gaussian Splats",
  },
  {
    group: "Real-time & finishing",
    items: "Unreal · Notch · TouchDesigner · DaVinci Resolve · Weavy",
  },
];

// Highlighted work — one reference video per project.
const sphereWork = [
  { title: "Backstreet Boys", note: "Residency", youtubeId: "4VEl7kvBRXk" },
  { title: "No Doubt", note: "Residency", youtubeId: "rmJt_mgxTOg" },
  { title: "Zac Brown", note: "Residency", youtubeId: "OouiujIfQHU" },
];
const beyondWork = [
  { title: "SeaWorld Abu Dhabi", note: "Themed entertainment", youtubeId: "xySIGEV1TZk" },
  { title: "Hong Kong Disneyland — Momentous", note: "Themed entertainment", youtubeId: "-p8kgnOujSY" },
];
---
<BaseLayout pageId="home">
  <section class="wrap" style="padding-top: clamp(3rem, 8vh, 6rem); padding-bottom: 2rem;">
    <div class="eyebrow">Generative Effects Supervisor · Sphere Studios</div>
    <h1 style="margin-top: 1.25rem;">
      I direct generative VFX<br />
      for the <em style="font-style: italic; color: var(--accent);">largest screens ever built.</em>
    </h1>
  </section>

  <!-- Tools of choice -->
  <section class="wrap" style="margin-top: 3.5rem;">
    <div class="eyebrow">Tools of choice</div>
    <div class="tools">
      {tools.map((t) => (
        <div class="tool-row">
          <div class="tool-group">{t.group}</div>
          <div class="tool-items">{t.items}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Highlighted work — one reference video each -->
  <section class="wrap" style="margin-top: 4.5rem; margin-bottom: 2rem;">
    <div class="eyebrow">Selected work</div>

    <h2 style="margin-top: 0.85rem; margin-bottom: 1.5rem;">At Sphere</h2>
    <div class="ref-grid">
      {sphereWork.map((item) => (
        <div class="ref-card">
          <VideoEmbed youtubeId={item.youtubeId} title={item.title} variant="project" />
          <div class="ref-cap">
            <span class="ref-name">{item.title}</span>
            <span class="ref-note">{item.note}</span>
          </div>
        </div>
      ))}
    </div>

    <h2 style="margin-top: 3.25rem; margin-bottom: 1.5rem;">Beyond Sphere</h2>
    <div class="ref-grid">
      {beyondWork.map((item) => (
        <div class="ref-card">
          <VideoEmbed youtubeId={item.youtubeId} title={item.title} variant="project" />
          <div class="ref-cap">
            <span class="ref-name">{item.title}</span>
            <span class="ref-note">{item.note}</span>
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  /* Tools of choice — editorial rows */
  .tools {
    margin-top: 1.25rem;
    max-width: 70rem;
  }
  .tool-row {
    display: grid;
    grid-template-columns: minmax(140px, 15rem) 1fr;
    gap: 1.5rem;
    padding: 1.1rem 0;
    border-top: 1px solid var(--line);
  }
  .tool-row:last-child {
    border-bottom: 1px solid var(--line);
  }
  .tool-group {
    font-family: var(--type-mono);
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent-soft);
  }
  .tool-items {
    color: var(--fg);
    line-height: 1.6;
  }
  @media (max-width: 640px) {
    .tool-row {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
  }

  /* Selected-work reference videos */
  .ref-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 420px), 1fr));
    gap: 1.6rem;
  }
  .ref-cap {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.85rem;
  }
  .ref-name {
    font-family: var(--type-display);
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    letter-spacing: -0.01em;
    color: var(--fg);
  }
  .ref-note {
    font-family: var(--type-mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-muted);
    white-space: nowrap;
  }
</style>
